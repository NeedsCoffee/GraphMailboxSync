# GraphMailboxSync default configuration
# Command-line parameters override values from this file.
# Use ; to separate multiple folder paths in include/exclude settings.

TENANT_ID=your-tenant-id
CLIENT_ID=your-app-client-id
CERTIFICATE_THUMBPRINT=your-certificate-thumbprint

# Optional common runtime defaults
# SOURCE_USER_PRINCIPAL_NAME=source@contoso.com
# TARGET_USER_PRINCIPAL_NAME=target@contoso.com
# SOURCE_FOLDER_PATH=\
# TARGET_FOLDER_PATH=
# IMPORT_DIRECTLY_INTO_TARGET_FOLDER=false
# OVERLAY_MODE=false
# COPY_EMPTY_FOLDERS=false
# INCLUDE_FOLDER_PATH=Inbox\Projects;Inbox\Reports
# EXCLUDE_FOLDER_PATH=Junk Email;RSS Subscriptions
# OLDEST=2025-01-01
# NEWEST=2025-01-31
# PREFLIGHT_ONLY=false
# FORCE=false
# EXPORT_BATCH_SIZE=20
